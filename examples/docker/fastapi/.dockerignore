# Keep the build context small and free of secrets/junk.
# Excluded files never enter the image or the build cache.

# Secrets and local config — never ship these in an image.
.env
.env.*
*.pem
*.key
secrets/

# Version control and CI
.git
.github

# Python caches and virtual envs
__pycache__/
*.pyc
.venv/
venv/
.mypy_cache/
.pytest_cache/
.ruff_cache/

# Tests, notebooks, docs, and local data (not runtime content)
tests/
notebooks/
*.ipynb
docs/
data/
*.log

# Docker files themselves
Dockerfile
.dockerignore
