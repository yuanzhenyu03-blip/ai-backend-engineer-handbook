# Copy to `.env` and adjust. Compose interpolates ${NAME} from this file.
#
# NON-SENSITIVE configuration ONLY. Never put secrets here — no passwords, API
# keys, private keys, or DATABASE_URLs that contain a password. Secrets are
# provided as files under ./.secrets/ (see README.md), not via .env.
#
# `.env` itself is git-ignored; this `.env.example` is the committed template.

APP_ENV=development
LOG_LEVEL=info
MODEL_NAME=gpt-4o-mini

# Non-sensitive PostgreSQL identifiers (the PASSWORD is a secret file, not here).
POSTGRES_DB=app
POSTGRES_USER=app
